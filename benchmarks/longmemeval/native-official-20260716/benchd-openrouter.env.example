# benchd-openrouter.env — OpenRouter credentials for LongMemEval scripts
# Copy this file to benchd-openrouter.env and fill in your API key.
# The evaluator (evaluate_qa_openrouter.py) expects this exact filename
# at ./benchd-openrouter.env (hardcoded CRED_FILE constant).
# Generation scripts accept --cred-file for an arbitrary path.
#
# SAFETY: benchd-openrouter.env is gitignored — NEVER commit real credentials.

# OpenRouter base URL (default shown)
BENCHD_API_BASE=https://openrouter.ai/api/v1

# Your OpenRouter API key — create one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
